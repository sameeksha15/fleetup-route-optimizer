# Copy to .env and fill in as needed. All values are optional.

# TomTom API key. When set, road geometry and online travel times come from
# TomTom with LIVE TRAFFIC. Leave empty to use free OSRM + the offline estimator.
TOMTOM_API_KEY=

# OSRM routing server for road geometry and online road-network travel times.
# Defaults to the public demo server; point at a self-hosted instance for production.
OSRM_BASE_URL=https://router.project-osrm.org

# Address geocoding for order import (free OpenStreetMap / Nominatim). Results are
# cached in the DB and throttled to Nominatim's policy; the TomTom key is never
# used for geocoding. Override the endpoint/User-Agent only if self-hosting.
GEOCODER_BASE_URL=https://nominatim.openstreetmap.org/search
GEOCODER_USER_AGENT=FleetUp/1.0 (fleet route optimization demo)

# SQLAlchemy database URL (defaults to a local SQLite file).
DATABASE_URL=sqlite:///./fleet.db

# Allowed frontend origins, JSON list. Must be exact origins (not "*") because
# auth uses credentialed cookies.
CORS_ORIGINS=["http://localhost:3000"]

# ---- Auth ----
# Secret used to sign session JWTs. Generate one with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
# If left empty, a random per-process secret is used (sessions reset on restart).
JWT_SECRET=
# Session lifetime in hours (default 168 = 7 days).
JWT_EXPIRE_HOURS=168
# Set true when serving over HTTPS so the session cookie is marked Secure.
COOKIE_SECURE=false
